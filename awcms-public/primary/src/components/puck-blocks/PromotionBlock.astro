---
import { createClientFromEnv } from "~/lib/supabase";
import { ExternalLink } from "lucide-react";
import { sanitizeHTML } from "~/utils/sanitize";

interface Props {
  promotionId?: string;
  variant?: "banner" | "card" | "hero";
  showImage?: boolean;
}

const { promotionId, variant = "banner", showImage = true } = Astro.props;

const supabase = createClientFromEnv(import.meta.env);
let promotion = null;

if (supabase && promotionId) {
  const { data } = await supabase
    .from("promotions")
    .select("*")
    .eq("id", promotionId)
    .single();

  if (data && data.status === "active") {
    promotion = data;
  }
}

// Helper Components
---

{
  !promotion ? (
    <div class="hidden" />
  ) : (
    <>
      {variant === "card" && (
        <div class="bg-white dark:bg-slate-800 rounded-xl overflow-hidden shadow-lg border border-slate-100 dark:border-slate-700 hover:shadow-xl transition-all duration-300 flex flex-col h-full my-6">
          {showImage && promotion.featured_image && (
            <img
              src={promotion.featured_image}
              alt={promotion.title}
              class="w-full h-48 object-cover"
              loading="lazy"
            />
          )}
          <div class="p-6">
            <h3 class="font-bold text-lg text-slate-900 dark:text-slate-100 mb-2">
              {promotion.title}
            </h3>
            <div
              class="text-sm text-slate-600 dark:text-slate-400 line-clamp-3 prose prose-sm dark:prose-invert mb-4"
              set:html={sanitizeHTML(promotion.description)}
            />

            {promotion.link && (
              <a
                href={promotion.link}
                target={promotion.target || "_self"}
                class="inline-flex items-center justify-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors"
              >
                {promotion.cta_text || "Learn More"}
                {promotion.target === "_blank" && (
                  <ExternalLink className="w-3 h-3 ml-2" client:load />
                )}
              </a>
            )}

            {promotion.code && (
              <div class="mt-4 pt-4 border-t border-slate-100 dark:border-slate-700 flex justify-between items-center text-xs">
                <span class="text-slate-500 dark:text-slate-400">
                  Promo Code:
                </span>
                <code class="bg-slate-100 dark:bg-slate-900 px-2 py-1 rounded text-slate-700 dark:text-slate-300 font-mono font-bold select-all">
                  {promotion.code}
                </code>
              </div>
            )}
          </div>
        </div>
      )}

      {variant === "hero" && (
        <div class="relative rounded-2xl overflow-hidden bg-slate-900 text-white min-h-[400px] flex items-center shadow-2xl my-8">
          {showImage && promotion.featured_image && (
            <div class="absolute inset-0 z-0">
              <img
                src={promotion.featured_image}
                alt={promotion.title}
                class="w-full h-full object-cover opacity-60"
              />
              <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/40 to-transparent" />
            </div>
          )}
          <div class="relative z-10 p-8 md:p-12 max-w-2xl">
            {promotion.discount_percentage > 0 && (
              <span class="inline-block bg-white/20 backdrop-blur text-white px-3 py-1 rounded-full text-sm font-medium mb-4">
                Save {promotion.discount_percentage}%
              </span>
            )}
            <h2 class="text-3xl md:text-4xl font-bold mb-4">
              {promotion.title}
            </h2>
            <div
              class="text-lg text-slate-200 mb-6 max-w-lg"
              set:html={sanitizeHTML(promotion.description)}
            />

            <div class="flex gap-4 items-center">
              {promotion.link && (
                <a
                  href={promotion.link}
                  target={promotion.target || "_self"}
                  class="inline-flex items-center justify-center px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors"
                >
                  {promotion.cta_text || "Learn More"}
                  {promotion.target === "_blank" && (
                    <ExternalLink className="w-3 h-3 ml-2" client:load />
                  )}
                </a>
              )}
              {promotion.code && (
                <div class="flex flex-col bg-white/10 backdrop-blur px-4 py-1.5 rounded-lg border border-white/20">
                  <span class="text-[10px] text-white/70 uppercase tracking-widest">
                    Code
                  </span>
                  <span class="font-mono font-bold text-lg tracking-wide">
                    {promotion.code}
                  </span>
                </div>
              )}
            </div>
          </div>
        </div>
      )}

      {variant === "banner" && (
        <div class="bg-gradient-to-r from-blue-600 to-indigo-700 rounded-xl p-8 text-white flex flex-col md:flex-row items-center gap-8 shadow-lg hover:shadow-2xl transition-all duration-300 my-8">
          {showImage && promotion.featured_image && (
            <div class="w-full md:w-1/3 shrink-0">
              <img
                src={promotion.featured_image}
                alt={promotion.title}
                class="w-full h-48 object-cover rounded-lg shadow-lg"
              />
            </div>
          )}
          <div class="flex-1 text-center md:text-left">
            <h3 class="text-2xl font-bold mb-2">{promotion.title}</h3>
            <div
              class="text-blue-100 mb-4 prose-invert"
              set:html={sanitizeHTML(promotion.description)}
            />
            <div class="flex flex-col md:flex-row items-center gap-4">
              {promotion.link && (
                <a
                  href={promotion.link}
                  target={promotion.target || "_self"}
                  class="inline-flex items-center justify-center px-6 py-2 bg-white text-blue-700 hover:bg-blue-50 font-medium rounded-lg transition-colors"
                >
                  {promotion.cta_text || "Learn More"}
                  {promotion.target === "_blank" && (
                    <ExternalLink className="w-3 h-3 ml-2" client:load />
                  )}
                </a>
              )}
              {promotion.code && (
                <div class="text-sm">
                  Use Code:{" "}
                  <span class="bg-white/20 px-2 py-1 rounded font-mono font-bold ml-1">
                    {promotion.code}
                  </span>
                </div>
              )}
            </div>
          </div>
        </div>
      )}
    </>
  )
}
