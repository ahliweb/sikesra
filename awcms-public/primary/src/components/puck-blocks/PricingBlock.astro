---
import Pricing from "~/components/widgets/Pricing.astro";

const { items = [], id, isDark, classes, bg } = Astro.props;

type PricingFeature = {
  text?: string;
};

type PricingItem = {
  title?: string;
  description?: string;
  price?: string;
  period?: string;
  features?: PricingFeature[];
  callToAction?: string;
  buttonText?: string;
  isPopular?: boolean;
  ribbonTitle?: string;
};

// Map Puck items to Pricing widget props
const safeItems = Array.isArray(items) ? (items as PricingItem[]) : [];
const prices = safeItems.map((item) => ({
  title: item.title,
  subtitle: item.description,
  price: item.price,
  period: item.period,
  items:
    item.features?.map((feature) => ({
      description: feature.text,
      icon: "tabler:check",
    })) || [],
  callToAction: item.callToAction
    ? {
        href: item.callToAction,
        text: item.buttonText || "Get Started",
        target: "_self", // or _blank if external, but usually internal
      }
    : undefined,
  hasRibbon: item.isPopular,
  ribbonTitle: item.ribbonTitle,
}));
---

<Pricing prices={prices} id={id} isDark={isDark} classes={classes} bg={bg} />
