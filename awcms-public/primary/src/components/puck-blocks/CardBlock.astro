---
interface Props {
    title?: string;
    titleColor?: string;
    description?: string;
    descriptionColor?: string;
    image?: string;
    link?: string;
    variant?: "default" | "bordered" | "shadow" | "glass";
    aspectRatio?: "video" | "standard" | "square";
    hoverEffect?: "none" | "lift" | "scale-image";
}

const {
    title,
    titleColor,
    description,
    descriptionColor,
    image,
    link,
    variant = "default",
    aspectRatio = "video",
    hoverEffect = "none",
} = Astro.props;

const variantClasses = {
    default: "bg-white dark:bg-slate-800",
    bordered:
        "bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700",
    shadow: "bg-white dark:bg-slate-800 shadow-lg",
    glass: "bg-white/20 backdrop-blur-md border border-white/30 shadow-lg text-white",
};

const aspectRatioClasses = {
    video: "aspect-video",
    standard: "aspect-[4/3]",
    square: "aspect-square",
};

const hoverEffectClasses = {
    none: "",
    lift: "hover:-translate-y-2 hover:shadow-xl",
    "scale-image": "group-hover:scale-105",
};

const isGlass = variant === "glass";
---

{
    link ? (
        <a
            href={link}
            class="block h-full transition-opacity outline-none focus:ring-2 focus:ring-blue-500 rounded-xl"
        >
            <div
                class:list={[
                    "rounded-xl overflow-hidden transition-all duration-300 h-full flex flex-col group",
                    variantClasses[variant] || variantClasses.default,
                    hoverEffect === "lift" ? hoverEffectClasses.lift : "",
                ]}
            >
                {image && (
                    <div
                        class:list={[
                            "overflow-hidden bg-slate-100 dark:bg-slate-900",
                            aspectRatioClasses[aspectRatio] ||
                                aspectRatioClasses.video,
                        ]}
                    >
                        <img
                            src={image}
                            alt={title || "Card image"}
                            class:list={[
                                "w-full h-full object-cover transition-transform duration-500",
                                hoverEffect === "scale-image"
                                    ? hoverEffectClasses["scale-image"]
                                    : "",
                            ]}
                            loading="lazy"
                        />
                    </div>
                )}
                <div class="p-6 flex-1 flex flex-col">
                    {title && (
                        <h3
                            class="text-xl font-bold mb-3 leading-tight"
                            style={{
                                color:
                                    titleColor ||
                                    (isGlass ? "#ffffff" : undefined),
                            }}
                            class:list={[
                                !titleColor &&
                                    !isGlass &&
                                    "text-slate-900 dark:text-slate-100",
                            ]}
                        >
                            {title}
                        </h3>
                    )}
                    {description && (
                        <p
                            class="text-base leading-relaxed"
                            style={{
                                color:
                                    descriptionColor ||
                                    (isGlass
                                        ? "rgba(255,255,255,0.8)"
                                        : undefined),
                            }}
                            class:list={[
                                !descriptionColor &&
                                    !isGlass &&
                                    "text-slate-600 dark:text-slate-400",
                            ]}
                        >
                            {description}
                        </p>
                    )}
                </div>
            </div>
        </a>
    ) : (
        <div
            class:list={[
                "rounded-xl overflow-hidden transition-all duration-300 h-full flex flex-col group",
                variantClasses[variant] || variantClasses.default,
                hoverEffect === "lift" ? hoverEffectClasses.lift : "",
            ]}
        >
            {image && (
                <div
                    class:list={[
                        "overflow-hidden bg-slate-100 dark:bg-slate-900",
                        aspectRatioClasses[aspectRatio] ||
                            aspectRatioClasses.video,
                    ]}
                >
                    <img
                        src={image}
                        alt={title || "Card image"}
                        class:list={[
                            "w-full h-full object-cover transition-transform duration-500",
                            hoverEffect === "scale-image"
                                ? hoverEffectClasses["scale-image"]
                                : "",
                        ]}
                        loading="lazy"
                    />
                </div>
            )}
            <div class="p-6 flex-1 flex flex-col">
                {title && (
                    <h3
                        class="text-xl font-bold mb-3 leading-tight"
                        style={{
                            color:
                                titleColor || (isGlass ? "#ffffff" : undefined),
                        }}
                        class:list={[
                            !titleColor &&
                                !isGlass &&
                                "text-slate-900 dark:text-slate-100",
                        ]}
                    >
                        {title}
                    </h3>
                )}
                {description && (
                    <p
                        class="text-base leading-relaxed"
                        style={{
                            color:
                                descriptionColor ||
                                (isGlass ? "rgba(255,255,255,0.8)" : undefined),
                        }}
                        class:list={[
                            !descriptionColor &&
                                !isGlass &&
                                "text-slate-600 dark:text-slate-400",
                        ]}
                    >
                        {description}
                    </p>
                )}
            </div>
        </div>
    )
}
