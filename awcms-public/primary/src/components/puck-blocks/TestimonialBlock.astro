---
import { Quote } from "lucide-react";

interface Props {
  quote?: string;
  name?: string;
  role?: string;
  avatar?: string;
  rating?: number;
  variant?: "card" | "simple" | "centered";
}

const { quote, name, role, avatar, rating = 5, variant = "card" } = Astro.props;

const stars = Array.from({ length: 5 }, (_, i) => i + 1);
---

{
  variant === "centered" && (
    <div class="text-center py-12 px-6">
      <Quote className="w-12 h-12 text-blue-200 mx-auto mb-6" client:load />
      <blockquote class="text-2xl text-slate-700 dark:text-slate-300 italic mb-6 max-w-3xl mx-auto">
        "{quote}"
      </blockquote>
      <div class="flex items-center justify-center gap-4">
        {avatar && (
          <img
            src={avatar}
            alt={name}
            class="w-16 h-16 rounded-full object-cover"
            loading="lazy"
          />
        )}
        <div>
          <p class="font-bold text-slate-800 dark:text-slate-200">{name}</p>
          <p class="text-slate-500 dark:text-slate-400 text-sm">{role}</p>
          {rating && (
            <div class="flex gap-1 mt-1 justify-center">
              {stars.map((star) => (
                <svg
                  class={`w-5 h-5 ${star <= rating ? "text-yellow-400" : "text-slate-200 dark:text-slate-600"}`}
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  )
}

{
  variant === "simple" && (
    <div class="py-6 border-l-4 border-blue-500 pl-6 my-6">
      <blockquote class="text-lg text-slate-700 dark:text-slate-300 italic mb-4">
        "{quote}"
      </blockquote>
      <div class="flex items-center gap-3">
        {avatar && (
          <img
            src={avatar}
            alt={name}
            class="w-10 h-10 rounded-full object-cover"
            loading="lazy"
          />
        )}
        <div>
          <p class="font-semibold text-slate-800 dark:text-slate-200">{name}</p>
          <p class="text-slate-500 dark:text-slate-400 text-sm">{role}</p>
        </div>
      </div>
    </div>
  )
}

{
  variant === "card" && (
    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-lg p-6 border border-slate-100 dark:border-slate-700 my-6">
      <div class="flex items-start gap-4 mb-4">
        {avatar ? (
          <img
            src={avatar}
            alt={name}
            class="w-14 h-14 rounded-full object-cover"
            loading="lazy"
          />
        ) : (
          <div class="w-14 h-14 rounded-full bg-blue-100 dark:bg-blue-900/50 flex items-center justify-center">
            <span class="text-xl font-bold text-blue-600 dark:text-blue-400">
              {name?.charAt(0)}
            </span>
          </div>
        )}
        <div class="flex-1">
          <p class="font-bold text-slate-800 dark:text-slate-200">{name}</p>
          <p class="text-slate-500 dark:text-slate-400 text-sm">{role}</p>
          {rating && (
            <div class="flex gap-1 mt-1">
              {stars.map((star) => (
                <svg
                  class={`w-4 h-4 ${star <= rating ? "text-yellow-400" : "text-slate-200 dark:text-slate-600"}`}
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
          )}
        </div>
        <Quote
          className="w-8 h-8 text-blue-100 dark:text-blue-900 flex-shrink-0"
          client:load
        />
      </div>
      <blockquote class="text-slate-600 dark:text-slate-300 italic">
        "{quote}"
      </blockquote>
    </div>
  )
}
