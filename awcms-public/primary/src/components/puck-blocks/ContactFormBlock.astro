---
import { Send, Mail, Phone, User, MessageCircle } from "lucide-react";

interface Props {
  title?: string;
  subtitle?: string;
  showName?: boolean;
  showPhone?: boolean;
  showSubject?: boolean;
  buttonText?: string;
  successMessage?: string;
  recipientEmail?: string;
  variant?: "default" | "card" | "minimal";
}

const {
  title,
  subtitle,
  showName = true,
  showPhone = false,
  showSubject = true,
  buttonText = "Send Message",
  // successMessage = "Thank you for your message!",
  recipientEmail, // Note: In a real app, don't expose this to client. Use a backend API handler.
  variant = "default",
} = Astro.props;

// For now, we'll point to a generic API endpoint or just prevent default for demo.
// In AWCMS, this should point to a dedicated form handler API.
---

<div
  class:list={[
    "w-full max-w-2xl mx-auto my-12",
    variant === "card" &&
      "bg-white dark:bg-slate-800 p-8 rounded-2xl shadow-xl border border-slate-100 dark:border-slate-700",
    variant === "minimal" && "border-l-4 border-blue-600 pl-8",
  ]}
>
  <div
    class="mb-8 text-center"
    class:list={[variant === "minimal" && "text-left"]}
  >
    {
      title && (
        <h2 class="text-3xl font-bold mb-3 text-slate-900 dark:text-slate-100">
          {title}
        </h2>
      )
    }
    {subtitle && <p class="text-slate-600 dark:text-slate-400">{subtitle}</p>}
  </div>

  <form class="space-y-6" action="/api/contact" method="POST">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {
        showName && (
          <div class="relative group">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400 group-focus-within:text-blue-500 transition-colors">
              <User className="w-5 h-5" client:load />
            </div>
            <input
              type="text"
              name="name"
              placeholder="Your Name"
              required
              class="w-full pl-10 pr-4 py-3 bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400 transition-all"
            />
          </div>
        )
      }
      <div class:list={["relative group", !showName && "col-span-2"]}>
        <div
          class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400 group-focus-within:text-blue-500 transition-colors"
        >
          <Mail className="w-5 h-5" client:load />
        </div>
        <input
          type="email"
          name="email"
          placeholder="Your Email"
          required
          class="w-full pl-10 pr-4 py-3 bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400 transition-all"
        />
      </div>
    </div>

    {
      showPhone && (
        <div class="relative group">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400 group-focus-within:text-blue-500 transition-colors">
            <Phone className="w-5 h-5" client:load />
          </div>
          <input
            type="tel"
            name="phone"
            placeholder="Your Phone (Optional)"
            class="w-full pl-10 pr-4 py-3 bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400 transition-all"
          />
        </div>
      )
    }

    {
      showSubject && (
        <div class="relative group">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400 group-focus-within:text-blue-500 transition-colors">
            <MessageCircle className="w-5 h-5" client:load />
          </div>
          <input
            type="text"
            name="subject"
            placeholder="Subject"
            class="w-full pl-10 pr-4 py-3 bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400 transition-all"
          />
        </div>
      )
    }

    <div class="relative group">
      <textarea
        name="message"
        rows="5"
        placeholder="How can we help you?"
        required
        class="w-full p-4 bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400 transition-all resize-y"
      ></textarea>
    </div>

    <input type="hidden" name="recipient" value={recipientEmail} />

    <button
      type="submit"
      class="w-full md:w-auto px-8 py-3 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg shadow-lg hover:shadow-blue-500/30 transition-all transform hover:-translate-y-0.5 flex items-center justify-center gap-2"
    >
      <span>{buttonText}</span>
      <Send className="w-4 h-4" client:load />
    </button>
  </form>
</div>
