---
import {
  Star,
  Zap,
  Shield,
  Heart,
  Award,
  Target,
  Users,
  Globe,
  Rocket,
  Check,
} from "lucide-react";

interface Props {
  icon?: string;
  title?: string;
  description?: string;
  iconColor?: string;
}

const { icon, title, description, iconColor } = Astro.props;

// eslint-disable-next-line @typescript-eslint/no-explicit-any
const iconMap: Record<string, any> = {
  star: Star,
  zap: Zap,
  shield: Shield,
  heart: Heart,
  award: Award,
  target: Target,
  users: Users,
  globe: Globe,
  rocket: Rocket,
  check: Check,
};

const IconComponent = iconMap[icon || "star"] || Star;
---

<div
  class="flex flex-col items-center text-center p-6 bg-white dark:bg-slate-800 rounded-lg shadow-sm"
>
  <div
    class="w-16 h-16 rounded-full flex items-center justify-center mb-4"
    style={{ backgroundColor: iconColor ? `${iconColor}20` : "#e2e8f0" }}
  >
    <IconComponent
      className="w-8 h-8"
      style={{ color: iconColor || "#64748b" }}
      client:load
    />
  </div>
  {
    title && (
      <h3 class="text-xl font-bold text-slate-800 dark:text-slate-200 mb-2">
        {title}
      </h3>
    )
  }
  {
    description && (
      <p class="text-slate-600 dark:text-slate-400">{description}</p>
    )
  }
</div>
