---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { getAdminPageBySlug } from "../lib/api";
import { t, getLocalizedPath, type Locale } from "../utils/i18n";
import { sanitizeHTML } from "../utils/sanitize";

export interface Props {
  slug: string;
  locale: Locale;
  heroImage?: string;
  backHref?: string;
}

const {
  slug,
  locale,
  heroImage = "/images/backgrounds/hero-students.webp",
  backHref,
} = Astro.props;

const page = slug ? await getAdminPageBySlug(slug, locale) : null;

if (!page) {
  Astro.response.status = 404;
}

const hasRenderableContent = Boolean(page?.content?.trim());
const resolvedBackHref = backHref || getLocalizedPath("/", locale);
---

<Layout
  title={page?.meta_title || page?.title || (locale === "id" ? "Halaman tidak ditemukan" : "Page not found")}
  description={page?.meta_description || page?.excerpt || ""}
  image={page?.og_image || page?.featured_image || "/images/og-image.jpg"}
>
  {
    page ? (
      <>
        <section
          class="hero-gradient text-white py-16 md:py-20"
          style={`--hero-image: url('${heroImage}');`}
        >
          <div class="container-custom">
            <nav class="text-sm text-blue-200 mb-4">
              <a href={getLocalizedPath("/", locale)} class="hover:text-white"
                >{t("nav.home", locale)}</a
              >
              <span class="mx-2">/</span>
              <span class="text-white">{page.title}</span>
            </nav>
            <h1 class="text-3xl md:text-5xl font-bold font-heading max-w-4xl">
              {page.title}
            </h1>
            {
              page.excerpt && (
                <p class="mt-4 max-w-3xl text-lg text-blue-100">{page.excerpt}</p>
              )
            }
          </div>
        </section>

        <section class="section-photo py-16 bg-gray-50 dark:bg-slate-900 transition-colors duration-200">
          <div class="container-custom">
            <article class="bg-white dark:bg-slate-800 rounded-2xl shadow-lg overflow-hidden transition-colors duration-200">
              {
                page.featured_image && (
                  <img
                    src={page.featured_image}
                    alt={page.title}
                    class="w-full aspect-[16/7] object-cover"
                    loading="lazy"
                  />
                )
              }

              <div class="p-8 md:p-12">
                {
                  hasRenderableContent ? (
                    <div
                      class="prose prose-lg dark:prose-invert max-w-none"
                      set:html={sanitizeHTML(page.content)}
                    />
                  ) : (
                    <div class="rounded-xl border border-dashed border-gray-300 dark:border-slate-600 p-6 text-sm text-gray-600 dark:text-gray-300">
                      {
                        locale === "id"
                          ? "Konten halaman ini belum tersedia untuk ditampilkan di portal publik."
                          : "This page does not have public content available yet."
                      }
                    </div>
                  )
                }

                {
                  page.updated_at && (
                    <div class="mt-8 pt-6 border-t border-gray-200 dark:border-slate-700 text-sm text-gray-500 dark:text-gray-400">
                      {locale === "id" ? "Diperbarui pada" : "Updated on"}{" "}
                      {new Date(page.updated_at).toLocaleDateString(locale === "id" ? "id-ID" : "en-US", {
                        day: "numeric",
                        month: "long",
                        year: "numeric",
                      })}
                    </div>
                  )
                }
              </div>
            </article>

            <div class="mt-8">
              <a
                href={resolvedBackHref}
                class="btn-outline dark:text-white dark:border-gray-600 dark:hover:bg-slate-800"
              >
                <Icon name="tabler:arrow-left" class="w-5 h-5 mr-2" />
                {t("common.back", locale)}
              </a>
            </div>
          </div>
        </section>
      </>
    ) : (
      <section class="py-20">
        <div class="container-custom max-w-3xl">
          <h1 class="text-3xl font-bold">
            {locale === "id" ? "Halaman tidak ditemukan" : "Page not found"}
          </h1>
          <p class="mt-4 text-gray-600 dark:text-gray-300">
            {
              locale === "id"
                ? "Halaman yang Anda cari belum tersedia atau sudah tidak dipublikasikan."
                : "The page you requested is unavailable or no longer published."
            }
          </p>
        </div>
      </section>
    )
  }
</Layout>
