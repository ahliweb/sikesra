# ============================================
# AWCMS-Micro SIKESRA - Environment Configuration Template
# ============================================
# Copy this file to .env and fill in your values.
# This file is gitignored - never commit secrets.
# ============================================

# --------------------------------------------
# GitHub Access
# --------------------------------------------
# Personal Access Token for authenticated API access (higher rate limits)
# Get from: https://github.com/settings/tokens (fine-grained, repo scope)
# GITHUB_TOKEN=ghp_your_token_here

# GitHub repository owner/login
# GITHUB_OWNER_LOGIN=ahliweb
# GITHUB_REPO=ahliweb/sikesra

# GitHub OAuth App credentials (if using GitHub OAuth for admin login)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_WEBHOOK_SECRET=

# --------------------------------------------
# Cloudflare Access
# --------------------------------------------
# Cloudflare API Token (for wrangler CLI and D1/R2 management)
# Get from: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Account Cloudflare API Token, D1 Edit, R2 Edit, Workers Edit
# CLOUDFLARE_API_TOKEN=your_token_here

# Cloudflare Account ID (found in Workers dashboard URL or account home)
# CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# Cloudflare Zone ID (if using custom domains)
# CLOUDFLARE_ZONE_ID=

# --------------------------------------------
# Cloudflare AI Gateway (for review/bonk workflows)
# --------------------------------------------
# CF_AI_GATEWAY_ACCOUNT_ID=
# CF_AI_GATEWAY_NAME=
# CF_AI_GATEWAY_TOKEN=

# --------------------------------------------
# D1 Database Configuration
# --------------------------------------------
# Primary database binding (matches wrangler.jsonc)
# D1_DATABASE_NAME=sikesra
# D1_DATABASE_ID=e2902bf9-1648-4a46-8971-e4acadfa09ec

# SIKESRA-specific database (if separate from primary)
# SIKESRA_DB_NAME=sikesra
# SIKESRA_DB_ID=e2902bf9-1648-4a46-8971-e4acadfa09ec

# --------------------------------------------
# R2 Bucket Configuration
# --------------------------------------------
# Media storage bucket (matches wrangler.jsonc)
# R2_MEDIA_BUCKET_NAME=sikesra

# SIKESRA document storage (if separate)
# R2_SIKESRA_DOCUMENTS_BUCKET_NAME=sikesra

# --------------------------------------------
# Upstream Sync Configuration
# --------------------------------------------
# Override upstream repository URL (usually not needed)
# AWCMS_UPSTREAM_URL=https://github.com/ahliweb/awcms-micro.git

# Override upstream branch/ref (usually not needed)
# AWCMS_UPSTREAM_REF=main

# Override protected paths file (usually not needed)
# AWCMS_PROTECTED_PATHS=./scripts/awcms-micro-protected-paths.txt

# --------------------------------------------
# Development Settings
# --------------------------------------------
# Enable pseudo-locale for i18n testing (set to 1 to enable)
# EMDASH_PSEUDO_LOCALE=1

# --------------------------------------------
# GitLab (for backup/mirror workflows, if applicable)
# --------------------------------------------
# GITLAB_PAT=
# GITLAB_MIRROR_URL=
