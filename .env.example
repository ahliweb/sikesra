# SIKESRA Kobar runtime example.
# Copy to .env.local for local development and fill secrets locally.
# Do not commit real credentials, tokens, private keys, or connection strings.

SIKESRA_DATABASE_NAME=sikesrakobar
SIKESRA_DATABASE_HOST=id1.ahlikoding.com
SIKESRA_BASE_DOMAIN=sikesrakobar.ahlikoding.com
SIKESRA_BASE_URL=https://sikesrakobar.ahlikoding.com
SIKESRA_ENV=
SIKESRA_R2_BUCKET=sikesra
SIKESRA_WORKER_NAME=sikesra-kobar
SIKESRA_HYPERDRIVE_BINDING=HYPERDRIVE
SIKESRA_HYPERDRIVE_NAME=sikesra-kobar-postgres
SIKESRA_HYPERDRIVE_USE_ACCESS=true
SIKESRA_HYPERDRIVE_ORIGIN_HOST=pg-sikesra-hyperdrive.ahlikoding.com
SIKESRA_HYPERDRIVE_DATABASE=sikesrakobar
SIKESRA_HYPERDRIVE_ORIGIN_SCHEME=postgresql
SIKESRA_HYPERDRIVE_ORIGIN_PORT=5432
SIKESRA_R2_BINDING=MEDIA_BUCKET

# Safety switch for scripts/deploy-smoke-worker.mjs. Leave false unless an
# operator intentionally wants to replace the live Worker with the smoke Worker.
SIKESRA_ALLOW_SMOKE_WORKER_DEPLOY=false

# Application URL aliases used by AWCMS Mini/EmDash integrations.
SITE_URL=https://sikesrakobar.ahlikoding.com
APP_BASE_URL=https://sikesrakobar.ahlikoding.com
PUBLIC_BASE_URL=https://sikesrakobar.ahlikoding.com
PUBLIC_SITE_URL=https://sikesrakobar.ahlikoding.com
BASE_URL=https://sikesrakobar.ahlikoding.com
PUBLIC_HOSTNAME=sikesrakobar.ahlikoding.com
APP_HOSTNAME=sikesrakobar.ahlikoding.com

# PostgreSQL values belong in local env files or Coolify locked runtime secrets.
# Use a least-privilege application user, not a superuser.
DATABASE_URL=
PGHOST=id1.ahlikoding.com
PGDATABASE=sikesrakobar
POSTGRES_HOST=id1.ahlikoding.com
POSTGRES_DB=sikesrakobar
POSTGRES_DATABASE=sikesrakobar
DATABASE_HOST=id1.ahlikoding.com
DATABASE_NAME=sikesrakobar
DB_NAME=sikesrakobar

# R2 bucket identifiers are non-secret. Access keys are secrets.
R2_BUCKET_NAME=sikesra
CLOUDFLARE_R2_BUCKET=sikesra
CLOUDFLARE_R2_BUCKET_NAME=sikesra
AWS_BUCKET=sikesra
AWS_S3_BUCKET=sikesra
S3_BUCKET=sikesra
BUCKET_NAME=sikesra

# Secret placeholders. Set real values in .env.local, Cloudflare Worker secrets,
# or Coolify locked secrets only.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_ACCESS_KEY=
COOLIFY_BASE_URL=
COOLIFY_ACCESS_TOKEN=
COOLIFY_SIKESRA_SERVER_UUID=
COOLIFY_SIKESRA_PROJECT_UUID=
COOLIFY_SIKESRA_ENVIRONMENT_NAME=
COOLIFY_SIKESRA_POSTGRES_RESOURCE_UUID=
CLOUDFLARE_ACCESS_CLIENT_ID=
CLOUDFLARE_ACCESS_CLIENT_SECRET=
CLOUDFLARE_ACCESS_SERVICE_TOKEN_ID=
TURNSTILE_SECRET_KEY=
SESSION_SECRET=
JWT_SECRET=
EDGE_API_JWT_SECRET=
APP_SECRET=
MINI_TOTP_ENCRYPTION_KEY=

# Optional local-only Hyperdrive compatibility value. Keep real connection
# strings in .env.local only; never commit them.
CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE=
