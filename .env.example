# GitHub Access (optional, for authenticated rate limits)
# Get from: https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_your_token_here

# Cloudflare API Token (optional, for D1/R2 operations)
# Get from: https://dash.cloudflare.com/profile/api-tokens
# CLOUDFLARE_API_TOKEN=your_token_here
# CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# Upstream sync overrides (usually not needed)
# AWCSM_UPSTREAM_URL=https://github.com/ahliweb/awcms-micro.git
# AWCSM_UPSTREAM_REF=main
# AWCSM_PROTECTED_PATHS=./scripts/awcms-micro-protected-paths.txt
