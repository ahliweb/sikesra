# SIKESRA environment variable contract.
# Copy to .env.local for local development and fill real values locally.
# Do not commit real credentials, tokens, private keys, or connection strings.
# Production backend secrets belong in Coolify environment variables or another reviewed deployment-managed secret store.

# ─── Core ────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000
APP_URL=https://sikesrakobar.ahlikoding.com
API_BASE_URL=https://sikesrakobar.ahlikoding.com/api
SITE_URL=https://sikesrakobar.ahlikoding.com

# ─── Database ────────────────────────────────────────────────────────────────
# Production: use internal Docker hostname (e.g. postgres:5432)
# Local: use 127.0.0.1 or tunnel host
DATABASE_URL=
# Optional migration-only override. Use when the operator migration environment
# differs from the runtime environment (e.g. running migrations from a bastion
# rather than inside the Docker network).
DATABASE_MIGRATION_URL=

# ─── Auth and Session ────────────────────────────────────────────────────────
JWT_SECRET=
SESSION_SECRET=
PASSWORD_PEPPER=

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=sikesra
R2_PUBLIC_BASE_URL=

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://sikesrakobar.ahlikoding.com

# ─── Cloudflare Turnstile ────────────────────────────────────────────────────
# TURNSTILE_SITE_KEY is safe to expose to the frontend.
# TURNSTILE_SECRET_KEY must remain backend-only.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# ─── Two-Factor Authentication (TOTP) ────────────────────────────────────────
TWO_FACTOR_ISSUER=SIKESRA
TWO_FACTOR_ENCRYPTION_KEY=
TWO_FACTOR_RECOVERY_CODE_PEPPER=

# ─── OpenAPI / Swagger UI ────────────────────────────────────────────────────
# Disable Swagger UI in production if the policy requires private API docs.
OPENAPI_ENABLED=true
OPENAPI_JSON_PATH=/openapi.json
SWAGGER_UI_ENABLED=true
SWAGGER_UI_PATH=/docs

# ─── Mailketing Email API ────────────────────────────────────────────────────
# Backend-only. Never expose MAILKETING_API_KEY to the frontend.
MAILKETING_ENABLED=false
MAILKETING_API_BASE_URL=
MAILKETING_API_KEY=
MAILKETING_SENDER_EMAIL=
MAILKETING_SENDER_NAME=SIKESRA
MAILKETING_WEBHOOK_SECRET=
MAILKETING_TIMEOUT_MS=10000
MAILKETING_MAX_RETRIES=3

# ─── Starsender WhatsApp API ─────────────────────────────────────────────────
# Backend-only. Never expose STARSENDER_API_KEY to the frontend.
STARSENDER_ENABLED=false
STARSENDER_API_BASE_URL=
STARSENDER_API_KEY=
STARSENDER_DEVICE_ID=
STARSENDER_DEFAULT_COUNTRY_CODE=62
STARSENDER_WEBHOOK_SECRET=
STARSENDER_TIMEOUT_MS=10000
STARSENDER_MAX_RETRIES=3

# ─── Notification Defaults ───────────────────────────────────────────────────
NOTIFICATION_RATE_LIMIT_PER_MINUTE=60
NOTIFICATION_RETRY_ENABLED=true
NOTIFICATION_DEFAULT_PROVIDER_EMAIL=mailketing
NOTIFICATION_DEFAULT_PROVIDER_WHATSAPP=starsender

# ─── Frontend (Cloudflare Pages) ─────────────────────────────────────────────
# These are safe to expose to the browser.
# Never put database credentials, R2 keys, or provider secrets here.
PUBLIC_API_BASE_URL=https://sikesrakobar.ahlikoding.com/api
PUBLIC_SITE_CODE=main
PUBLIC_APP_ENV=production
PUBLIC_TURNSTILE_SITE_KEY=

# ─── Coolify Operator Scripts ────────────────────────────────────────────────
# Used by scripts/verify-runtime-readiness.mjs only.
COOLIFY_BASE_URL=
COOLIFY_ACCESS_TOKEN=
COOLIFY_SIKESRA_POSTGRES_RESOURCE_UUID=

# ─── Cloudflare Operator Scripts ─────────────────────────────────────────────
# CLOUDFLARE_API_TOKEN is used by reviewed Cloudflare operator scripts and audits.
CLOUDFLARE_API_TOKEN=
