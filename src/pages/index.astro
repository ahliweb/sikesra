<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EmDash Public Web</title>
    <style>
      :root {
        --bg: #f8fafc;
        --text: #0f172a;
        --muted: #475569;
        --card: #ffffff;
        --border: #dbe2ea;
        --brand: #2271b1;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
        color: var(--text);
        background: var(--bg);
      }
      .wrap {
        max-width: 720px;
        margin: 0 auto;
        padding: 48px 20px;
      }
      .card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 24px;
      }
      h1 {
        margin: 0 0 12px;
        font-size: 1.6rem;
      }
      p { margin: 0 0 12px; color: var(--muted); line-height: 1.55; }
      .actions {
        margin-top: 16px;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }
      a {
        text-decoration: none;
        border-radius: 8px;
        padding: 10px 14px;
        border: 1px solid var(--border);
        color: var(--text);
        background: #fff;
      }
      a.primary {
        background: var(--brand);
        border-color: var(--brand);
        color: #fff;
      }
    </style>
  </head>
  <body>
    <main class="wrap">
      <section class="card">
        <h1>EmDash Public Web</h1>
        <p>This is the default public homepage served by the EmDash host runtime.</p>
        <p>Use admin for management and use SIKESRA for the aggregate public module page.</p>
        <div class="actions">
          <a class="primary" href="/_emdash/admin">Open EmDash Admin</a>
          <a href="/sikesra">Open SIKESRA Public Page</a>
        </div>
      </section>
    </main>
  </body>
</html>
