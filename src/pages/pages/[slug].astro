---
import { env } from "cloudflare:workers";

const { slug } = Astro.params;
if (!slug) {
  return Astro.redirect("/404");
}

const page = await env.DB.prepare("SELECT id, title, slug, body, excerpt, status, published_at, created_at, updated_at, author_id FROM ec_pages WHERE slug = ? AND deleted_at IS NULL LIMIT 1").bind(slug).first();

if (!page || page.status !== "published") {
  return Astro.redirect("/404");
}
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{page.title}</title>
    <meta name="description" content={page.excerpt || page.title} />
  </head>
  <body>
    <header>
      <nav>
        <a href="/">SIKESRA KOBAR</a>
      </nav>
    </header>
    <main>
      <article>
        <h1>{page.title}</h1>
        {page.published_at && (
          <time datetime={page.published_at}>
            {new Date(page.published_at).toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </time>
        )}
        <div set:html={page.body || ""} />
      </article>
    </main>
    <footer>
      <p>&copy; {new Date().getFullYear()} SIKESRA KOBAR</p>
    </footer>
  </body>
</html>
