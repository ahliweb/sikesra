{
	"$schema": "https://emdashcms.com/seed.schema.json",
	"version": "1",
	"meta": {
		"name": "AWCMS-Micro Cloudflare Gallery Seed",
		"description": "Gallery collection seed for the Cloudflare AWCMS-Micro template.",
		"author": "AWCMS-Micro"
	},
	"collections": [
		{
			"slug": "galleries",
			"label": "Galleries",
			"labelSingular": "Gallery",
			"supports": ["drafts", "revisions", "search", "seo"],
			"fields": [
				{ "slug": "title", "label": "Title", "type": "string", "required": true, "searchable": true },
				{ "slug": "description", "label": "Description", "type": "text", "searchable": true },
				{ "slug": "cover_image", "label": "Cover Image", "type": "image" },
				{ "slug": "gallery_type", "label": "Gallery Type", "type": "select", "required": true, "validation": { "options": ["photo", "video", "mixed"] } },
				{ "slug": "event_date", "label": "Event Date", "type": "datetime" },
				{ "slug": "location", "label": "Location", "type": "string", "searchable": true },
				{ "slug": "layout_variant", "label": "Layout Variant", "type": "select", "required": true, "validation": { "options": ["grid", "masonry", "carousel", "slider"] } },
				{ "slug": "gallery_items", "label": "Gallery Items", "type": "json", "required": true },
				{ "slug": "featured", "label": "Featured", "type": "boolean" }
			]
		}
	],
	"content": {
		"galleries": [
			{
				"id": "cloudflare-media-gallery",
				"slug": "cloudflare-media-gallery",
				"status": "published",
				"data": {
					"title": "Cloudflare Media Gallery",
					"description": "A Cloudflare-ready mixed gallery that can use EmDash media, R2 objects, Cloudflare Images, or Cloudflare Stream URLs without exposing private keys.",
					"cover_image": { "src": "https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=1200&q=80", "alt": "Team reviewing media assets on laptops" },
					"gallery_type": "mixed",
					"event_date": "2026-05-10T10:30:00.000Z",
					"location": "Cloudflare Production Template",
					"layout_variant": "carousel",
					"featured": true,
					"gallery_items": [
						{ "type": "image", "src": "https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=1200&q=80", "mimeType": "image/jpeg", "filename": "cloudflare-gallery-dashboard.jpg", "sizeBytes": 480000, "alt": "Team reviewing gallery deployment assets", "caption": "Media remains public-only while private R2 credentials stay in Cloudflare bindings.", "provider": "external" },
						{ "type": "video", "src": "https://interactive-examples.mdn.mozilla.net/media/cc0-videos/flower.mp4", "mimeType": "video/mp4", "filename": "cloudflare-stream-placeholder.mp4", "sizeBytes": 1120000, "caption": "Video item compatible with a future Cloudflare Stream playback URL.", "provider": "external" }
					]
				}
			}
		]
	}
}
