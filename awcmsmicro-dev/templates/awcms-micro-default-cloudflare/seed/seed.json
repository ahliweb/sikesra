		"posts": [
			{
				"id": "cloudflare-ready-awcms-micro",
				"slug": "cloudflare-ready-awcms-micro",
				"status": "published",
				"data": {
					"title": "Operating AWCMS-Micro on Cloudflare",
					"excerpt": "How AWCMS-Micro uses EmDash, D1, R2, and Astro to keep publishing and admin operations on one deployment path.",
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "This post explains the intended AWCMS-Micro production model: public pages render from EmDash-managed content, while editors authenticate into the standard admin route to create, publish, and govern that content.",
									"_key": "p2"
								}
							],
							"_key": "b2"
						}
					]
				},
				"bylines": [
					{
						"byline": "byline-awcms-editorial"
					}
				],
				"taxonomies": {
					"category": ["platform"],
					"tag": ["awcms-micro", "cloudflare"]
				}
			},
			{
				"id": "cloudflare-ready-awcms-micro-id",
				"translationOf": "cloudflare-ready-awcms-micro",
				"locale": "id",
				"slug": "cloudflare-ready-awcms-micro",
				"status": "published",
				"data": {
					"title": "Menjalankan AWCMS-Micro di Cloudflare",
					"excerpt": "Bagaimana AWCMS-Micro menggunakan EmDash, D1, R2, dan Astro untuk menjaga publishing dan operasi admin dalam satu jalur deployment.",
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Pos ini menjelaskan model produksi AWCMS-Micro yang dituju: halaman publik dirender dari konten yang dikelola EmDash, sementara editor masuk ke route admin standar untuk membuat, mempublikasikan, dan mengelola konten tersebut.",
									"_key": "p2-id"
								}
							],
							"_key": "b2-id"
						}
					]
				},
				"bylines": [
					{
						"byline": "byline-awcms-editorial"
					}
				],
				"taxonomies": {
					"category": ["platform"],
					"tag": ["awcms-micro", "cloudflare"]
				}
			}
		],
