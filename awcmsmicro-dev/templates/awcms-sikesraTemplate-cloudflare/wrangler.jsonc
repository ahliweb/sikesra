{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "sikesra",
	"main": "./src/worker.ts",
	"compatibility_date": "2026-05-14",
	"compatibility_flags": ["nodejs_compat"],
	"placement": { "mode": "smart" },
	"routes": [
		{
			"pattern": "sikesra.ahlikoding.com/*",
			"zone_name": "ahlikoding.com",
			"custom_domain": false
		}
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "sikesra",
			"database_id": "e2902bf9-1648-4a46-8971-e4acadfa09ec"
		}
	],
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "sikesra"
		}
	],
	"kv_namespaces": [
		{
			"binding": "SESSION",
			"id": "29e3fd9bbf2f448fa3b36185b8be299a"
		}
	],
	"images": {
		"binding": "IMAGES"
	},
	"worker_loaders": [
		{
			"binding": "LOADER"
		}
	],
	"vars": {
		"AWCMS_SIKESRA_SITE_URL": "https://sikesra.ahlikoding.com"
	},
	"observability": {
		"enabled": true
	}
}
