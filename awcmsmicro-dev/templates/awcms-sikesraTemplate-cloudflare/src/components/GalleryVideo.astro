---
interface Props {
	src: string;
	caption?: string;
	poster?: string;
	mimeType?: string;
}

const { src, caption, poster, mimeType = "video/mp4" } = Astro.props;
const linkLabel = (Astro.currentLocale || "en").startsWith("id") ? "Buka video" : "Open video";
---

<figure class="gallery-video">
	<video controls preload="metadata" poster={poster} playsinline>
		<source src={src} type={mimeType} />
		<a href={src}>{linkLabel}</a>
	</video>
	{caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
	.gallery-video {
		margin: 0;
	}

	.gallery-video video {
		width: 100%;
		border-radius: 1rem;
		background: #020617;
	}

	.gallery-video figcaption {
		margin-top: 0.45rem;
		color: var(--text-muted);
		font-size: 0.92rem;
	}
</style>
