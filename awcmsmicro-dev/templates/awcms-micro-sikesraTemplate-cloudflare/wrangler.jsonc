{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "sikesra",
	"main": "./src/worker.ts",
	"compatibility_date": "2026-02-24",
	"compatibility_flags": ["nodejs_compat"],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "sikesra",
			"database_id": "e2902bf9-1648-4a46-8971-e4acadfa09ec",
		},
	],
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "sikesra",
		},
	],
	// Worker Loader for plugin sandboxing
	"worker_loaders": [
		{
			"binding": "LOADER",
		},
	],
}
