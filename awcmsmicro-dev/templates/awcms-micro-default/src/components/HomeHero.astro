---
import { getPublicCopy } from "../utils/public-copy";
import { getI18nConfig } from "emdash";

const i18nConfig = getI18nConfig();
const defaultLocale = i18nConfig?.defaultLocale || "en";
const currentLocale = Astro.locals.awcmsLocale || Astro.currentLocale || defaultLocale;
const copy = getPublicCopy(currentLocale);
---

<section class="hero-section">
	<div class="hero-glow"></div>
	<div class="hero-container">
		<span class="hero-kicker">{copy.homeKicker}</span>
		<h1 class="hero-title">{copy.heroTitle}</h1>
		<p class="hero-subtitle">{copy.heroSubtitle}</p>
		<div class="hero-ctas">
			<a class="btn btn-primary" href="/_emdash/admin/login?redirect=/_emdash/admin">
				{copy.heroCtaPrimary}
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-arrow"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
			</a>
			<a class="btn btn-secondary" href="/docs" data-astro-prefetch="hover">
				{copy.heroCtaSecondary}
			</a>
		</div>
	</div>
</section>

<style>
	.hero-section {
		position: relative;
		padding: 7rem 1.5rem;
		text-align: center;
		overflow: hidden;
		background: var(--gradient-surface);
		border: 1px solid var(--surface-border);
		border-radius: 2rem;
		margin-bottom: 3rem;
		box-shadow: var(--shadow-xl);
	}

	.hero-glow {
		position: absolute;
		top: -50%;
		left: -50%;
		width: 200%;
		height: 200%;
		background: radial-gradient(circle, rgba(217, 70, 239, 0.08) 0%, rgba(99, 102, 241, 0.04) 50%, transparent 100%);
		pointer-events: none;
		z-index: 0;
		animation: pulse-glow 15s infinite alternate ease-in-out;
	}

	@keyframes pulse-glow {
		0% { transform: scale(1) translate(0, 0); }
		100% { transform: scale(1.05) translate(1%, 1%); }
	}

	.hero-container {
		position: relative;
		z-index: 1;
		max-width: 48rem;
		margin: 0 auto;
	}

	.hero-kicker {
		display: inline-block;
		font-size: 0.875rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: var(--accent);
		margin-bottom: 1.5rem;
		background: rgba(99, 102, 241, 0.08);
		padding: 0.35rem 1.25rem;
		border-radius: 999px;
		border: 1px solid rgba(99, 102, 241, 0.15);
	}

	.hero-title {
		font-size: clamp(2.5rem, 6vw, 4.5rem);
		font-weight: 800;
		line-height: 1.1;
		color: var(--text-main);
		margin: 0 0 1.5rem;
		letter-spacing: -0.03em;
		background: var(--gradient-primary);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	:root.dark .hero-title {
		background: linear-gradient(135deg, #ffffff 10%, #6366f1 50%, #d946ef 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.hero-subtitle {
		font-size: clamp(1.125rem, 2vw, 1.25rem);
		line-height: 1.7;
		color: var(--text-muted);
		margin: 0 0 2.5rem;
	}

	.hero-ctas {
		display: flex;
		justify-content: center;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.875rem 2.25rem;
		border-radius: 999px;
		font-weight: 700;
		font-size: 1rem;
		transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
		cursor: pointer;
		text-decoration: none;
	}

	.btn-primary {
		background: var(--gradient-primary);
		color: #ffffff;
		border: none;
		box-shadow: 0 4px 20px rgba(99, 102, 241, 0.25);
		position: relative;
	}

	.btn-primary::after {
		content: '';
		position: absolute;
		top: -2px;
		left: -2px;
		right: -2px;
		bottom: -2px;
		border-radius: 999px;
		background: var(--gradient-primary);
		z-index: -1;
		opacity: 0.4;
		transition: transform 0.5s ease, opacity 0.5s ease;
	}

	.btn-primary:hover::after {
		transform: scale(1.08, 1.15);
		opacity: 0;
	}

	.btn-primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 30px rgba(99, 102, 241, 0.4);
		color: #ffffff;
	}

	.btn-primary:hover .icon-arrow {
		transform: translateX(4px);
	}

	.btn-secondary {
		background: var(--surface-main);
		color: var(--text-main);
		border: 1px solid var(--surface-border);
		backdrop-filter: blur(8px);
	}

	.btn-secondary:hover {
		background: var(--surface-border);
		transform: translateY(-2px);
	}

	.icon-arrow {
		transition: transform 0.3s ease;
	}
</style>
