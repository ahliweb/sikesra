---
import { getGalleryCopy } from "../utils/gallery-copy";

interface Props {
	href: string;
	title: string;
	description?: string;
	cover?: { src?: string; alt?: string } | string | null;
	type?: string;
	location?: string;
	date?: string;
	featured?: boolean;
}

const { href, title, description, cover, type, location, date, featured } = Astro.props;
const coverSrc = typeof cover === "string" ? cover : cover?.src;
const coverAlt = typeof cover === "string" ? title : cover?.alt || title;
const eventDate = date ? new Date(date) : null;
const currentLocale = Astro.currentLocale || "en";
const copy = getGalleryCopy(currentLocale);
---

<article class="gallery-card">
	<a href={href} class="gallery-card__media" data-astro-prefetch="hover">
		{coverSrc ? <img src={coverSrc} alt={coverAlt} loading="lazy" /> : <div class="gallery-card__placeholder">{copy.placeholder}</div>}
	</a>
	<div class="gallery-card__body">
		<div class="gallery-card__meta">
			{type && <span>{type}</span>}
			{featured && <span>{copy.featured}</span>}
		</div>
		<h2><a href={href} data-astro-prefetch="hover">{title}</a></h2>
		{description && <p>{description}</p>}
		{(location || eventDate) && (
			<p class="gallery-card__details">
				{location}{location && eventDate ? " · " : ""}{eventDate?.toLocaleDateString(currentLocale, { dateStyle: "medium" })}
			</p>
		)}
	</div>
</article>

<style>
	.gallery-card {
		overflow: hidden;
		border: 1px solid var(--surface-border);
		border-radius: 1.25rem;
		background: var(--surface-main);
		box-shadow: 0 18px 32px rgba(15, 23, 42, 0.08);
	}

	.gallery-card__media {
		display: block;
		aspect-ratio: 4 / 3;
		background: var(--gradient-surface);
	}

	.gallery-card__media img,
	.gallery-card__placeholder {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.gallery-card__placeholder {
		display: grid;
		place-items: center;
		color: var(--text-muted);
	}

	.gallery-card__body {
		padding: 1rem;
	}

	.gallery-card__meta {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
		margin-bottom: 0.6rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		font-size: 0.72rem;
		font-weight: 800;
		color: var(--accent);
	}

	.gallery-card h2 {
		margin: 0 0 0.45rem;
		font-size: 1.35rem;
	}

	.gallery-card p {
		margin: 0.35rem 0 0;
		color: var(--text-muted);
	}
</style>
