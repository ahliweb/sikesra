{
	"$schema": "https://emdashcms.com/seed.schema.json",
	"version": "1",
	"meta": {
		"name": "AWCMS-Micro Default Template",
		"description": "Local-development AWCMS-Micro template showing public content wired to the EmDash admin workflow",
		"author": "AWCMS-Micro"
	},
	"settings": {
		"title": "AWCMS-Micro",
		"tagline": "A compact EmDash implementation for single-tenant teams and Cloudflare-ready delivery."
	},
	"collections": [
		{
			"slug": "posts",
			"label": "Posts",
			"labelSingular": "Post",
			"supports": ["drafts", "revisions", "search", "seo"],
			"fields": [
				{ "slug": "title", "label": "Title", "type": "string", "required": true, "searchable": true },
				{ "slug": "featured_image", "label": "Featured Image", "type": "image" },
				{ "slug": "content", "label": "Content", "type": "portableText", "searchable": true },
				{ "slug": "excerpt", "label": "Excerpt", "type": "text" }
			]
		},
		{
			"slug": "news",
			"label": "News",
			"labelSingular": "News Item",
			"supports": ["drafts", "revisions", "search", "seo"],
			"fields": [
				{ "slug": "title", "label": "Title", "type": "string", "required": true, "searchable": true },
				{ "slug": "summary", "label": "Summary", "type": "text", "searchable": true },
				{ "slug": "content", "label": "Content", "type": "portableText", "searchable": true }
			]
		},
		{
			"slug": "pages",
			"label": "Pages",
			"labelSingular": "Page",
			"supports": ["drafts", "revisions", "search"],
			"fields": [
				{
					"slug": "title",
					"label": "Title",
					"type": "string",
					"required": true,
					"searchable": true
				},
				{
					"slug": "content",
					"label": "Content",
					"type": "portableText",
					"searchable": true
				}
			]
		},
		{
			"slug": "galleries",
			"label": "Galleries",
			"labelSingular": "Gallery",
			"supports": ["drafts", "revisions", "search", "seo"],
			"fields": [
				{ "slug": "title", "label": "Title", "type": "string", "required": true, "searchable": true },
				{ "slug": "description", "label": "Description", "type": "text", "searchable": true },
				{ "slug": "cover_image", "label": "Cover Image", "type": "image" },
				{ "slug": "gallery_type", "label": "Gallery Type", "type": "select", "required": true, "validation": { "options": ["photo", "video", "mixed"] } },
				{ "slug": "event_date", "label": "Event Date", "type": "datetime" },
				{ "slug": "location", "label": "Location", "type": "string", "searchable": true },
				{ "slug": "layout_variant", "label": "Layout Variant", "type": "select", "required": true, "validation": { "options": ["grid", "masonry", "carousel", "slider"] } },
				{ "slug": "gallery_items", "label": "Gallery Items", "type": "json", "required": true },
				{ "slug": "featured", "label": "Featured", "type": "boolean" }
			]
		}
	],
