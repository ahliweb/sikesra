---
import { decodeSlug, getEmDashEntry, getI18nConfig, getSeoMeta, getSiteSettings } from "emdash";
import { PortableText } from "emdash/ui";
import BaseLayout from "../layouts/BaseLayout.astro";
import { toLocalePath } from "../utils/locale-path";
import { resolveAwcmsMicroSiteIdentity } from "../utils/site-identity";

function asString(value: unknown) {
	return typeof value === "string" ? value : String(value ?? "");
}

const slug = decodeSlug(Astro.params.slug);

if (!slug) return Astro.redirect("/404");

const { entry: page, cacheHint } = await getEmDashEntry("pages", slug);

if (!page) return Astro.redirect("/404");

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);
const i18nConfig = getI18nConfig();
const defaultLocale = i18nConfig?.defaultLocale || "en";
const currentLocale = Astro.locals.awcmsLocale || Astro.currentLocale || defaultLocale;
const localeOptions = {
	defaultLocale,
	locales: i18nConfig?.locales || ["en", "id"],
};
const { siteTitle } = resolveAwcmsMicroSiteIdentity(await getSiteSettings());
const seo = getSeoMeta(page, {
	siteTitle,
	siteUrl: Astro.url.origin,
	path: toLocalePath(`/${slug}`, currentLocale, localeOptions),
});
---

<BaseLayout
	title={seo.title}
	pageTitle={seo.ogTitle}
	description={seo.description}
	canonical={seo.canonical}
	content={{ collection: "pages", id: asString(page.data.id), slug }}
>
	<section>
		<h1 {...page.edit.title}>{page.data.title}</h1>
		<PortableText value={page.data.content} />
	</section>
</BaseLayout>
