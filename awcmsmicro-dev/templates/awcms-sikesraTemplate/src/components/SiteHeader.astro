---
const currentLocale = Astro.currentLocale || "en";
const isId = currentLocale.startsWith("id");
const navigationLabel = isId ? "Navigasi utama" : "Primary navigation";
const navigation = [
	{ href: "/", label: isId ? "Beranda" : "Home" },
	{ href: "/about", label: isId ? "Tentang" : "About" },
];
---

<header>
	<div class="shell">
		<div>
			<p class="eyebrow">AWCMS-Micro example</p>
			<h1>AWCMS-Micro Default Site</h1>
			<p class="tagline">Single-tenant-first, tenant-ready, and EmDash-compatible.</p>
		</div>
		<nav aria-label={navigationLabel}>
			<ul>
				{navigation.map((item) => (
					<li><a href={item.href}>{item.label}</a></li>
				))}
			</ul>
		</nav>
	</div>
</header>

<style>
	header {
		background: #111827;
		color: #f9fafb;
	}

	.shell {
		max-width: 72rem;
		margin: 0 auto;
		padding: 2rem 1.25rem;
		display: flex;
		justify-content: space-between;
		gap: 2rem;
		align-items: end;
		flex-wrap: wrap;
	}

	.eyebrow {
		text-transform: uppercase;
		letter-spacing: 0.08em;
		font-size: 0.8rem;
		margin: 0 0 0.5rem;
		color: #93c5fd;
	}

	h1 {
		margin: 0;
		font-size: clamp(2rem, 4vw, 3rem);
	}

	.tagline {
		margin: 0.75rem 0 0;
		max-width: 38rem;
	}

	ul {
		list-style: none;
		display: flex;
		gap: 1rem;
		padding: 0;
		margin: 0;
	}

	a {
		color: inherit;
		text-decoration: none;
		font-weight: 600;
	}
</style>
