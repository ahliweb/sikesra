{
	"id": "awcms-micro-gallery",
	"name": "AWCMS-Micro Gallery",
	"version": "0.0.4",
	"license": "LicenseRef-AW-NC-1.0",
	"description": "Advanced gallery management helpers for AWCMS-Micro without modifying EmDash core.",
	"entrypoint": "@awcms-micro/plugin-gallery/sandbox",
	"format": "standard",
	"capabilities": [
		"content:read",
		"content:write",
		"media:read",
		"media:write",
		"network:request:unrestricted",
	],
	"adminPages": [{ "path": "/", "label": "Gallery", "labelKey": "gallery.label", "icon": "image" }],
	"navigation": {
		"groups": [
			{
				"id": "gallery-group",
				"labelKey": "gallery.group",
				"fallbackLabel": "Gallery",
				"icon": "image",
				"sortOrder": 10,
				"sidebarPlacement": "after-dashboard",
				"sidebarPriority": 10,
				"items": [
					{
						"id": "gallery-home",
						"labelKey": "gallery.label",
						"fallbackLabel": "Gallery",
						"path": "/",
						"icon": "image",
						"sortOrder": 10,
					},
				],
			},
		],
	},
}
