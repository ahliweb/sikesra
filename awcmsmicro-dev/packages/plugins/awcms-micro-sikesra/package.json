{
	"name": "@ahliweb/awcms-micro-sikesra",
	"version": "0.1.0",
	"description": "Canonical AWCMS-Micro SIKESRA plugin package for EmDash workspaces",
	"type": "module",
	"main": "dist/index.mjs",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"types": "./dist/index.d.mts"
		},
		"./sandbox": "./dist/sandbox-entry.mjs"
	},
	"files": [
		"dist",
		"src",
		"migrations",
		"seeds",
		"module.manifest.json",
		"README.md"
	],
	"keywords": [
		"awcms-micro",
		"emdash",
		"plugin",
		"sikesra",
		"welfare"
	],
	"license": "MIT",
	"dependencies": {
		"kysely": "^0.27.0"
	},
	"peerDependencies": {
		"emdash": "workspace:*"
	},
	"devDependencies": {
		"better-sqlite3": "catalog:",
		"tsdown": "catalog:",
		"vitest": "catalog:"
	},
	"scripts": {
		"build": "tsdown src/index.ts src/sandbox-entry.ts --format esm --dts --clean",
		"test": "vitest run",
		"typecheck": "tsgo --noEmit"
	}
}
