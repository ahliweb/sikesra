{
  "name": "awcms-micro-sikesra",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "Independent SIKESRA implementation based on AWCMS-Micro",
  "scripts": {
    "sync:upstream": "bash scripts/sync-from-awcms-micro.sh --validate",
    "sync:dry-run": "bash scripts/sync-from-awcms-micro.sh --dry-run",
    "sync:force": "bash scripts/sync-from-awcms-micro.sh --no-backup --validate",
    "d1:backup:sikesra": "bash scripts/backup-sikesra-d1.sh",
    "validate:boundaries": "bash scripts/validate-awcmsmicro-boundaries.sh",
    "awcmsmicro:update-awcmsmicro-dev": "bash scripts/update-awcmsmicro-dev.sh",
    "awcmsmicro:validate-boundaries": "bash scripts/validate-awcmsmicro-boundaries.sh",
    "awcmsmicro:validate-after-sync": "bash scripts/validate-after-sync.sh",
    "awcmsmicro:sync-and-validate": "bash scripts/sync-and-validate.sh",
    "dev": "pnpm --dir awcmsmicro-dev dev",
    "build": "pnpm --dir awcmsmicro-dev build",
    "test": "pnpm --dir awcmsmicro-dev test"
  },
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=20"
  }
}
