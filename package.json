{
  "name": "awcms-mini-sikesra",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "audit:coolify-postgres": "node scripts/audit-coolify-postgres.mjs",
    "audit:database-role": "node scripts/audit-database-role.mjs",
    "check": "node scripts/check-secret-hygiene.mjs && node --import tsx/esm --test tests/unit/*.test.mjs",
    "check:secret-hygiene": "node scripts/check-secret-hygiene.mjs",
    "dev:emdash-core": "node scripts/dev-emdash-core.mjs",
    "dev:emdash-core:stop": "node scripts/dev-emdash-core-stop.mjs",
    "deploy:checklist": "node scripts/deploy-checklist.mjs",
    "docker:local:up": "docker compose --env-file .env.local -f compose.local.yaml up -d --build",
    "docker:local:down": "docker compose --env-file .env.local -f compose.local.yaml down",
    "docker:local:logs": "docker compose --env-file .env.local -f compose.local.yaml logs -f api postgres",
    "docker:local:migrate": "docker compose --env-file .env.local -f compose.local.yaml exec api pnpm db:migrate",
    "docker:local:psql": "docker compose --env-file .env.local -f compose.local.yaml exec postgres psql -U sikesra -d sikesrakobar",
    "db:migrate": "tsx scripts/db-migrate.ts up",
    "db:migrate:probe": "tsx scripts/db-migrate.ts probe",
    "db:migrate:status": "tsx scripts/db-migrate.ts status",
    "db:seed": "tsx scripts/db-seed.ts",
    "smoke:cloudflare-admin": "node scripts/smoke-cloudflare-admin.mjs",
    "smoke:deployed-runtime-health": "node scripts/smoke-deployed-runtime-health.mjs",
    "verify:live-runtime": "node scripts/verify-live-runtime.mjs",
    "test:unit": "node --import tsx/esm --test tests/unit/*.test.mjs",
    "lint": "node scripts/check-secret-hygiene.mjs",
    "api:build": "tsc -p tsconfig.api.json",
    "api:dev": "node --watch --import tsx/esm src/api/index.ts",
    "api:start": "node dist/api/index.js"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "hono": "^4.7.7",
    "postgres": "^3.4.5",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
