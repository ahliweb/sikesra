{
  "name": "@ahliweb/plugin-sikesra",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SIKESRA — Sistem Informasi Kesejahteraan Rakyat as an EmDash-native plugin (self-contained host)",
  "main": "src/plugin-entry.ts",
  "exports": {
    ".": {
      "import": "./src/plugin-entry.ts"
    }
  },
  "scripts": {
    "postinstall": "node scripts/patch-emdash-content-cache.mjs",
    "test": "vitest run",
    "typecheck": "astro check && tsc --noEmit",
    "dev": "astro dev",
    "sync:emdash": "node scripts/sync-emdash-upstream.mjs",
    "build": "astro build",
    "postbuild": "node scripts/postbuild.mjs",
    "preview": "astro preview",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.5.0",
    "@astrojs/react": "^5.0.4",
    "@emdash-cms/cloudflare": "^0.10.0",
    "astro": "^6.3.1",
    "emdash": "^0.10.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@cloudflare/workers-types": "^4.20260508.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1",
    "wrangler": "^4.90.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd",
      "better-sqlite3"
    ]
  },
  "keywords": [
    "sikesra",
    "welfare",
    "emdash",
    "awcms"
  ],
  "license": "SEE LICENSE IN LICENSE"
}
