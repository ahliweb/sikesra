{
  "rules": [
    {
      "allowed": {
        "origins": [
          "http://localhost:3000",
          "http://127.0.0.1:3000",
          "https://awcms.ahliweb.com"
        ],
        "methods": ["GET", "HEAD", "PUT"],
        "headers": ["Content-Type"]
      },
      "exposeHeaders": ["ETag"],
      "maxAgeSeconds": 3600
    }
  ]
}
