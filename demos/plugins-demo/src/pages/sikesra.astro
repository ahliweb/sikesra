---
---

<html lang="id">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>SIKESRA</title>
		<style>
			:root {
				color-scheme: light dark;
				font-family: system-ui, -apple-system, sans-serif;
				--bg: #f4f8fb;
				--text: #10263b;
				--text-muted: #4b647c;
				--card-bg: #ffffff;
				--card-border: #d8e4ef;
				--card-shadow: rgba(15, 61, 102, 0.06);
				--hero-from: #0f3d66;
				--hero-to: #0e7490;
				--hero-text: #ffffff;
				--notice-bg: #fff8e8;
				--notice-border: #f7d89d;
				--notice-text: #5a3e0a;
				--link: #0a5a6e;
			}
			@media (prefers-color-scheme: dark) {
				:root {
					--bg: #0f1724;
					--text: #e8edf2;
					--text-muted: #94a3b8;
					--card-bg: #1a2636;
					--card-border: #2d3f52;
					--card-shadow: rgba(0, 0, 0, 0.3);
					--hero-from: #0c2d4d;
					--hero-to: #0a5a6e;
					--hero-text: #e8edf2;
					--notice-bg: #2a2110;
					--notice-border: #6b5418;
					--notice-text: #f0d98a;
					--link: #22d3ee;
				}
			}
			body {
				margin: 0;
				background: var(--bg);
				color: var(--text);
			}
			main {
				max-width: 960px;
				margin: 0 auto;
				padding: 2rem 1rem 3rem;
			}
			.hero {
				background: linear-gradient(135deg, var(--hero-from), var(--hero-to));
				color: var(--hero-text);
				padding: 2rem 1.25rem;
				border-radius: 20px;
			}
			.hero p {
				max-width: 720px;
			}
			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
				gap: 1rem;
				margin-top: 1.5rem;
			}
			.card {
				background: var(--card-bg);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				padding: 1rem;
				box-shadow: 0 8px 30px var(--card-shadow);
			}
			.label {
				font-size: 0.8rem;
				text-transform: uppercase;
				letter-spacing: 0.04em;
				color: var(--text-muted);
			}
			.value {
				font-size: 1.8rem;
				font-weight: 700;
				margin-top: 0.25rem;
			}
			.panel {
				margin-top: 1.5rem;
			}
			.panel h2 {
				font-size: 1.1rem;
				margin: 0 0 0.75rem;
			}
			.notice {
				background: var(--notice-bg);
				border: 1px solid var(--notice-border);
				border-radius: 14px;
				padding: 1rem;
				color: var(--notice-text);
				margin-top: 1rem;
			}
			.route-list {
				margin: 0;
				padding-left: 1.2rem;
			}
			a {
				color: var(--link);
			}
		</style>
	</head>
	<body>
		<main>
			<section class="hero">
				<p>SIKESRA</p>
				<h1>Sistem Informasi Kesejahteraan Rakyat</h1>
				<p id="description">
					Memuat metadata publik SIKESRA dari plugin overlay.
				</p>
			</section>

			<section class="grid" aria-label="Ringkasan publik SIKESRA">
				<div class="card">
					<div class="label">Status</div>
					<div class="value" id="enabled">...</div>
				</div>
				<div class="card">
					<div class="label">Total Entitas</div>
					<div class="value" id="total-entities">0</div>
				</div>
				<div class="card">
					<div class="label">Terverifikasi</div>
					<div class="value" id="verified-entities">0</div>
				</div>
				<div class="card">
					<div class="label">Desa Aktif</div>
					<div class="value" id="active-villages">0</div>
				</div>
			</section>

			<section class="panel card">
				<h2>Catatan Integrasi</h2>
				<p id="scope-note">
					Route shell sudah aktif. Data, ABAC, audit, dan workflow dipulihkan bertahap.
				</p>
				<ul class="route-list">
					<li><code>/_emdash/admin/plugins/sikesra/</code></li>
					<li><code>/_emdash/api/plugins/sikesra/public/*</code></li>
					<li><code>/_emdash/api/plugins/sikesra/v1/*</code></li>
				</ul>
			</section>

			<section class="notice" id="caveat">
				Halaman ini hanya menampilkan data agregat aman publik.
			</section>

			<p class="panel">
				Buka <a href="/_emdash/admin/plugins/sikesra/">admin plugin SIKESRA</a> untuk memverifikasi mount admin.
			</p>
		</main>

		<script is:inline>
			const base = "/_emdash/api/plugins/sikesra/public";

			async function loadJson(path) {
				const response = await fetch(`${base}${path}`);
				if (!response.ok) throw new Error(`Request failed: ${path}`);
				return response.json();
			}

			Promise.all([loadJson("/metadata"), loadJson("/summary")])
				.then(([metadata, summary]) => {
					document.getElementById("enabled").textContent = metadata.enabled ? "Aktif" : "Nonaktif";
					document.getElementById("description").textContent = metadata.description;
					document.getElementById("scope-note").textContent = metadata.dataScopeNote;
					document.getElementById("total-entities").textContent = String(summary.kpis.totalEntities);
					document.getElementById("verified-entities").textContent = String(summary.kpis.verifiedEntities);
					document.getElementById("active-villages").textContent = String(summary.kpis.activeVillages);
					document.getElementById("caveat").textContent = summary.caveat;
					return null;
				})
				.catch((error) => {
					document.getElementById("enabled").textContent = "Gagal";
					document.getElementById("description").textContent =
						"Gagal memuat data SIKESRA dari plugin shell.";
					console.error(error);
					return null;
				});
		</script>
	</body>
</html>
